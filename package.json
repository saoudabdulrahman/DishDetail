{
  "name": "dishdetail",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:client dev:server",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspaces --if-present",
    "seed": "npm run seed --workspace=server",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:watch:client": "npm run test:watch --workspace=client",
    "test:watch:server": "npm run test:watch --workspace=server",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "lint-staged": {
    "client/**/*.{js,jsx}": [
      "eslint --config client/eslint.config.js --fix",
      "prettier --write"
    ],
    "server/**/*.{js,cjs,mjs}": [
      "eslint --config server/eslint.config.js --fix",
      "prettier --write"
    ],
    "**/*.{json,md,css,html}": [
      "prettier --write"
    ]
  }
}
